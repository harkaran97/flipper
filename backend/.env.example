# ============================================================
# Flipper Backend — Environment Variables
# Copy this file to .env for local development
# Set these in Railway dashboard for production
# ============================================================

# Database (Railway provides this automatically as DATABASE_URL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/flipper

# Anthropic (required for AI fault detection)
ANTHROPIC_API_KEY=sk-ant-...

# eBay Browse API (required for listing ingestion)
EBAY_APP_ID=your-ebay-app-id
EBAY_CERT_ID=your-ebay-cert-id

# LinkUp (required for web search enrichment)
LINKUP_API_KEY=your-linkup-api-key

# Stub modes (set to true for development, false for production)
EBAY_STUB=true
LINKUP_STUB=true

# Polling interval in seconds (default 180 = 3 minutes)
POLL_INTERVAL_SECONDS=180

# Opportunity alert threshold (default 0.6)
ALERT_SCORE_THRESHOLD=0.6

# eBay location filter (max distance from USER_POSTCODE)
EBAY_MAX_DISTANCE_MILES=50
USER_POSTCODE=LE4 8JF
