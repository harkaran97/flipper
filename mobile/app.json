{
  "expo": {
    "name": "Flipper",
    "slug": "flipper",
    "owner": "harkarankava",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "bundleIdentifier": "com.flipper.app",
      "supportsTablet": false
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#00C853"
        }
      ]
    ],
    "jsEngine": "hermes",
    "scheme": "flipper",
    "extra": {
      "eas": {
        "projectId": "8615c55d-2311-41b9-a5c6-c1e5c7b0c444"
      }
    }
  }
}
